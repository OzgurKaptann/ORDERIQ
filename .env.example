# --- API ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/orderiq
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MEDIA_DIR=media
FRONTEND_BASE_URL=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# SSR-only: internal docker URL so Next.js server-side fetches reach the api container
# Overridden automatically in docker-compose; only needed if running Next.js outside docker
API_URL=http://localhost:8000
